generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth adapters
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  password      String?
  resetToken    String?
  resetTokenExpiry DateTime?
  emailSent    Boolean?  @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  addresses Address[]
  orders    Order[]
  subscriptions Subscription[]
  loyaltyLedger LoyaltyLedger[]
  reviews Review[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires   DateTime

  @@unique([identifier, token])
}

// Address
model Address {
  id        String       @id @default(cuid())
  userId    String
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pin       String
  country   String       @default("India")
  isDefault Boolean      @default(false)
  type      AddressType  @default(SHIPPING)

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  CUSTOMER
  ADMIN
}

enum AddressType {
  SHIPPING
  BILLING
}

// Product
model Product {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String
  category        ProductCategory
  basePrice       Int             // price in rupees (e.g. 1999 = ₹1,999)
  comparePrice    Int?
  images          String[]        // JSON array of image URLs
  isActive        Boolean         @default(true)
  featured        Boolean         @default(false)
  nutritionFacts  String?        // JSON string
  ingredients     String?
  directions      String?
  servingSize     String?
  calories        Int?
  protein         Float?
  carbs           Float?
  fat             Float?

  variants  ProductVariant[]
  reviews   Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductCategory {
  PRE_WORKOUT
  PROTEIN
  MASS_GAINER
  OMEGA_3
  MULTIVITAMIN
}

// Product Variant
model ProductVariant {
  id           String  @id @default(cuid())
  productId    String
  flavor       String
  size         String?
  price        Int     // price in rupees
  comparePrice Int?
  sku          String  @unique
  weightG      Int?

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  inventory      Inventory[]
  subscriptionItems SubscriptionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Location
model Location {
  id        String   @id @default(cuid())
  name      String
  address   String
  isActive  Boolean  @default(true)

  inventory Inventory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Inventory
model Inventory {
  id                 String   @id @default(cuid())
  productVariantId   String
  locationId         String
  quantity           Int      @default(0)
  lowStockThreshold  Int      @default(10)

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  location      Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productVariantId, locationId])
}

// Order
model Order {
  id                 String       @id @default(cuid())
  orderNumber        String      @unique
  userId             String?
  status             OrderStatus  @default(PENDING)
  shippingAddressId  String?
  subtotal           Int         // price in rupees
  shippingCost       Int         @default(0)
  tax                Int         @default(0)
  discount           Int         @default(0)
  total              Int         // price in rupees
  paymentMethod      PaymentMethod
  razorpayOrderId    String?
  razorpayPaymentId  String?
  stripePaymentIntent String?
  trackingNumber       String?   // AWB code from Shiprocket
  trackingCarrier      String?   // courier name from Shiprocket
  shiprocketOrderId    String?   // Shiprocket internal order ID
  shiprocketShipmentId String?   // Shiprocket shipment ID
  loyaltyPointsEarned  Int       @default(0)

  user          User?           @relation(fields: [userId], references: [id])
  shippingAddress Address?      @relation(fields: [shippingAddressId], references: [id])
  items         OrderItem[]
  loyaltyLedger LoyaltyLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  STRIPE
  COD
}

// Order Item
model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productVariantId String
  quantity        Int
  unitPrice       Int      // price in rupees

  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Subscription
model Subscription {
  id            String           @id @default(cuid())
  userId        String
  status        SubscriptionStatus @default(ACTIVE)
  nextBilling   DateTime
  discountPct   Int              @default(0)

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  SubscriptionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionItem {
  id                 String              @id @default(cuid())
  subscriptionId     String
  productVariantId   String
  frequency          SubscriptionFrequency

  subscription   Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum SubscriptionFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

// Loyalty Ledger
model LoyaltyLedger {
  id          String       @id @default(cuid())
  userId      String
  points      Int
  type        LoyaltyType
  orderId     String?
  description String

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order?   @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LoyaltyType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
}

// Review
model Review {
  id               String   @id @default(cuid())
  userId           String
  productId        String
  rating           Int      // 1-5
  title            String?
  body             String
  photos           String[] // JSON array of photo URLs (stored as JSONB)
  isVerifiedPurchase Boolean @default(false)
  helpfulCount     Int      @default(0)
  isApproved       Boolean  @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// CartAbandonment
model CartAbandonment {
  id            String   @id @default(cuid())
  userId        String?
  email         String?
  phone         String?
  guestName     String?
  cartData      Json?    // { items: [{name, flavor, price, quantity}], couponCode, discount, shippingCost }
  lastActiveAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reminderSent  Boolean  @default(false)
  recoveryLink  String?
  orderId       String?  // Set if user completes checkout

  @@index([email])
  @@index([phone])
  @@index([lastActiveAt])
}